{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"root": true,
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": { "useConst": "error", "noNonNullAssertion": "off" }
		},
		"includes": ["**", "!**/node_modules/", "!**/.next", "!**/.source", "!**/bun.lock", "!**/next-env.d.ts"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 130,
		"includes": ["**", "!**/node_modules/", "!**/.next", "!**/.source", "!**/bun.lock", "!**/next-env.d.ts"]
	},
	"javascript": {
		"formatter": { "trailingCommas": "none" }
	},
	"css": {
		"parser": { "tailwindDirectives": true }
	},
	"files": {
		"includes": ["**", "!**/node_modules/", "!!**/.next", "!**/.source", "!**/bun.lock", "!**/next-env.d.ts"]
	}
}
